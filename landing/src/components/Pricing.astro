---
---

<section id="pricing" class="py-20 lg:py-28 border-t border-slate-800/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Enkel prissättning</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">Börja gratis. Uppgradera när du behöver mer.</p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      <!-- Free -->
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-8">
        <h3 class="text-lg font-semibold text-slate-300">Free</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="text-4xl font-bold">$0</span>
          <span class="text-slate-500">/mån</span>
        </div>
        <p class="mt-4 text-sm text-slate-400">Perfekt för att prova på.</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-300">
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            3 bevakade sidor
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            100 checks/mån
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            AI-sammanfattning
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            E-postnotiser
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            7 dagars historik
          </li>
        </ul>
        <a href="#" class="mt-8 block rounded-lg border border-slate-700 py-3 text-center font-semibold text-slate-300 transition hover:border-slate-500 hover:text-white">
          Kom igång gratis
        </a>
      </div>

      <!-- Pro (highlighted) -->
      <div class="relative rounded-2xl border-2 border-blue-500 bg-slate-900/80 p-8 shadow-lg shadow-blue-500/10">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-blue-600 px-4 py-1 text-sm font-semibold">
          Populärast
        </div>
        <h3 class="text-lg font-semibold text-white">Pro</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="text-4xl font-bold">$19</span>
          <span class="text-slate-500">/mån</span>
        </div>
        <p class="mt-1 text-xs text-slate-500">eller $190/år (spara 17%)</p>
        <p class="mt-4 text-sm text-slate-400">För produktchefer och småföretag.</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-300">
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            25 bevakade sidor
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            2 000 checks/mån
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            AI + importance score
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Slack + e-postnotiser
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            90 dagars historik
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Schemalägg var 15:e minut
          </li>
        </ul>
        <a href="#" class="mt-8 block rounded-lg bg-blue-600 py-3 text-center font-semibold text-white shadow-lg shadow-blue-500/25 transition hover:bg-blue-500">
          Starta Pro
        </a>
      </div>

      <!-- Team -->
      <div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-8">
        <h3 class="text-lg font-semibold text-slate-300">Team</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="text-4xl font-bold">$49</span>
          <span class="text-slate-500">/mån</span>
        </div>
        <p class="mt-1 text-xs text-slate-500">eller $490/år (spara 17%)</p>
        <p class="mt-4 text-sm text-slate-400">För team som bevakar många sidor.</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-300">
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            100 bevakade sidor
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            10 000 checks/mån
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Allt i Pro
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Teams, PagerDuty, Jira
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            REST API & webhooks
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            1 år historik, 5 användare
          </li>
        </ul>
        <a href="#" class="mt-8 block rounded-lg border border-slate-700 py-3 text-center font-semibold text-slate-300 transition hover:border-slate-500 hover:text-white">
          Starta Team
        </a>
      </div>
    </div>
  </div>
</section>
