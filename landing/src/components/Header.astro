---
import { lt, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const otherLang = lang === 'en' ? 'sv' : 'en';
const otherUrl = lang === 'en' ? '/sv' : '/';
---

<header class="fixed top-4 left-4 right-4 z-50">
  <div class="mx-auto max-w-6xl rounded-2xl glass-strong px-6 py-3">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-lg font-bold tracking-tight">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600">
          <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="3" />
            <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z" />
          </svg>
        </div>
        <span class="theme-text">change<span class="text-blue-600">brief</span></span>
      </a>
      <div class="flex items-center gap-3">
        <a href={lang === 'sv' ? '/sv/compliance' : '/compliance'} class="hidden sm:inline-flex cursor-pointer text-sm font-medium theme-text-secondary hover:theme-text transition-all duration-200">
          {lang === 'sv' ? 'Compliance' : 'Compliance'}
        </a>
        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="cursor-pointer rounded-lg p-1.5 theme-text-muted hover:theme-text transition-all duration-200"
          title="Toggle dark/light mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="h-4 w-4 hidden" id="theme-sun" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="h-4 w-4" id="theme-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <a href={otherUrl} class="cursor-pointer rounded-lg theme-bg-muted px-2 py-1 text-xs font-medium theme-text-muted hover:theme-text transition-all duration-200">
          {otherLang.toUpperCase()}
        </a>
        <a
          href="#pricing"
          class="btn-glow rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-5 py-2 text-sm font-semibold text-white transition-all duration-200"
        >
          {lt('header.cta', lang)}
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    var toggle = document.getElementById('theme-toggle');
    var sun = document.getElementById('theme-sun');
    var moon = document.getElementById('theme-moon');

    function updateIcons() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (sun && moon) {
        sun.style.display = isDark ? 'block' : 'none';
        moon.style.display = isDark ? 'none' : 'block';
      }
    }

    updateIcons();

    if (toggle) {
      toggle.addEventListener('click', function() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('cb-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('cb-theme', 'dark');
        }
        updateIcons();
      });
    }
  })();
</script>
