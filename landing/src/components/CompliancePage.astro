---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import { lt, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;

const title = lang === 'sv'
  ? 'changebrief — Regulatorisk omvärldsbevakning med AI'
  : 'changebrief — AI-powered regulatory monitoring';
const description = lt('reg.sub', lang);

const canonical = lang === 'sv'
  ? 'https://changebrief.io/sv/compliance'
  : 'https://changebrief.io/compliance';

const hreflang = [
  { lang: 'en', href: 'https://changebrief.io/compliance' },
  { lang: 'sv', href: 'https://changebrief.io/sv/compliance' },
  { lang: 'x-default', href: 'https://changebrief.io/compliance' },
];

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [1,2,3,4].map(n => ({
    '@type': 'Question',
    name: lt(`reg.faq.q${n}` as any, lang),
    acceptedAnswer: {
      '@type': 'Answer',
      text: lt(`reg.faq.a${n}` as any, lang),
    },
  })),
};

const structuredData = [{
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'changebrief',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: lang === 'sv'
    ? 'AI-driven regulatorisk omvärldsbevakning. Bevaka myndigheter och tillsynsorgan automatiskt.'
    : 'AI-powered regulatory monitoring. Track government agencies and regulators automatically.',
  url: 'https://changebrief.io/compliance',
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: '3 pages, 100 checks/month',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '29',
      priceCurrency: 'USD',
      description: '25 pages, 2000 checks/month, daily digest, CSV export',
    },
  ],
  featureList: [
    'AI compliance classification',
    'Jurisdiction tagging (SE, EU, US)',
    'Document type identification',
    'Action-level badges',
    'RSS feeds per sector',
    'Audit trail CSV export',
    'Weekly/daily compliance digest',
  ],
}, faqData];
---

<Base title={title} description={description} lang={lang} canonical={canonical} hreflang={hreflang} structuredData={structuredData}>
  <Header lang={lang} />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36 bg-gradient-to-b from-red-50/60 to-white">
      <div class="relative mx-auto max-w-6xl px-6 text-center">
        <div class="mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full bg-red-50 border border-red-100 px-4 py-2 text-sm text-red-700">
          <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-red-500"></span></span>
          {lt('reg.badge', lang)}
        </div>
        <h1 class="mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight text-slate-900 sm:text-6xl lg:text-7xl">
          {lt('reg.h1a', lang)}
          <span class="block bg-gradient-to-r from-red-600 via-amber-500 to-orange-500 bg-clip-text text-transparent">{lt('reg.h1b', lang)}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed text-slate-600 lg:text-xl">
          <span class="text-slate-900 font-semibold">change</span><span class="text-blue-600 font-semibold">brief</span> {lang === 'sv' ? 'bevakar myndigheter och tillsynsorgan med AI — och berättar exakt vad som ändrades, om det kräver åtgärd och vilken jurisdiktion som berörs.' : 'monitors government agencies and regulators with AI — and tells you exactly what changed, whether it requires action, and which jurisdiction it affects.'}
        </p>
        <div class="mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="https://app.changebrief.io?ref=compliance" class="btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-600 to-amber-600 px-8 py-3.5 text-base font-semibold text-white transition-all duration-300">
            {lt('reg.cta1', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="#how-it-works" class="group inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-8 py-3.5 text-base font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:text-slate-900 hover:shadow-sm">
            {lt('reg.cta2', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
        </div>

        <!-- Demo card -->
        <div class="mt-16 mx-auto max-w-lg animate-fade-in-up delay-400">
          <div class="glass-card rounded-2xl p-6 text-left space-y-3">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-red-50 border border-red-100 px-2.5 py-1 text-xs font-medium text-red-700">
                <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                {lang === 'sv' ? 'Åtgärd krävs' : 'Action required'}
              </span>
              <span class="rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-600">SE</span>
              <span class="rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-600">{lang === 'sv' ? 'Föreskrift' : 'Regulation'}</span>
            </div>
            <p class="text-sm text-slate-700">{lang === 'sv' ? '"Finansinspektionen publicerade FFFS 2026:4 som skärper kraven på AML-rapportering. Ikraftträdande: 1 juli 2026."' : '"Finansinspektionen published FFFS 2026:4 tightening AML reporting requirements. Effective date: July 1, 2026."'}</p>
            <div class="flex items-center gap-2 text-xs text-slate-500">
              <span class="rounded-full bg-red-50 px-1.5 py-0.5 text-red-600 font-medium">9/10</span>
              <span>fi.se</span>
              <span class="text-slate-300">|</span>
              <span>{lang === 'sv' ? '14 mar 2026, 08:15' : 'Mar 14, 2026, 08:15'}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem / Before & After -->
    <section id="how-it-works" class="relative py-24 lg:py-32 border-t border-slate-100">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{lt('reg.problem.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-600">{lt('reg.problem.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-8 md:grid-cols-2">
          <!-- Before -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-6 flex items-center gap-2 text-sm font-semibold text-red-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" /></svg>
              {lt('reg.problem.before', lang)}
            </div>
            <ul class="space-y-4 text-slate-600 text-[15px]">
              {[lt('reg.problem.b1', lang), lt('reg.problem.b2', lang), lt('reg.problem.b3', lang), lt('reg.problem.b4', lang)].map(item => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-red-400"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <!-- After -->
          <div class="animate-fade-in-up rounded-2xl border-2 border-emerald-200 bg-emerald-50/30 p-8">
            <div class="mb-6 flex items-center gap-2 text-sm font-semibold text-emerald-600">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
              {lt('reg.problem.after', lang)}
            </div>
            <ul class="space-y-4 text-slate-700 text-[15px]">
              {[lt('reg.problem.a1', lang), lt('reg.problem.a2', lang), lt('reg.problem.a3', lang), lt('reg.problem.a4', lang)].map(item => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="relative py-24 lg:py-32 bg-slate-50/50 border-t border-slate-100">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{lt('reg.how.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">{lt('reg.how.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-8 md:grid-cols-3">
          {[
            { step: 'reg.how.s1', icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10', color: 'red' },
            { step: 'reg.how.s2', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', color: 'amber' },
            { step: 'reg.how.s3', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', color: 'emerald' },
          ].map(({ step, icon, color }) => (
            <div class="animate-fade-in-up text-center">
              <div class={`mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-${color}-50 text-${color}-600`}>
                <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} /></svg>
              </div>
              <div class={`mb-2 text-xs font-semibold uppercase tracking-widest text-${color}-600/70`}>{lt(`${step}` as any, lang)}</div>
              <h3 class="text-xl font-bold text-slate-900">{lt(`${step}.h` as any, lang)}</h3>
              <p class="mt-2 text-slate-600 text-[15px] leading-relaxed">{lt(`${step}.p` as any, lang)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why changebrief -->
    <section class="relative py-24 lg:py-32 bg-white border-t border-slate-100">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{lt('reg.why.h2', lang)}</h2>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2">
          <!-- Web monitoring -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.why.web.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.why.web.p', lang)}</p>
          </div>
          <!-- AI analysis -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.why.ai.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.why.ai.p', lang)}</p>
          </div>
          <!-- Open platform -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.why.open.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.why.open.p', lang)}</p>
          </div>
          <!-- API-first -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-50 text-purple-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.why.api.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.why.api.p', lang)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ISO section -->
    <section class="relative py-24 lg:py-32 bg-blue-50/30 border-t border-slate-100">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{lt('reg.iso.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-600">{lt('reg.iso.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-3">
          <!-- Audit trail -->
          <div class="animate-fade-in-up rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.iso.audit.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.iso.audit.p', lang)}</p>
          </div>
          <!-- Kvittens -->
          <div class="animate-fade-in-up rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.iso.kvittens.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.iso.kvittens.p', lang)}</p>
          </div>
          <!-- Overview -->
          <div class="animate-fade-in-up rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.iso.overview.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.iso.overview.p', lang)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="relative py-24 lg:py-32 bg-slate-50/50 border-t border-slate-100">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">{lt('reg.feat.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">{lt('reg.feat.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-red-50 text-red-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.feat.classify.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.feat.classify.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.feat.juris.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.feat.juris.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.feat.doctype.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.feat.doctype.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900">{lt('reg.feat.audit.h', lang)}</h3>
            <p class="mt-3 text-slate-600 text-[15px] leading-relaxed">{lt('reg.feat.audit.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-50 text-purple-600">
