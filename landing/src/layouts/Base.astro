---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "changebrief — Se vad som ändrades, inte bara att något ändrades",
  description = "changebrief bevakar webbsidor och berättar med AI exakt vad som hände. Inga suddiga screenshots. Inga röda pixlar. Bara en tydlig mening."
} = Astro.props;
---

<!doctype html>
<html lang="sv" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://changebrief.io" />
    <meta property="og:image" content="https://changebrief.io/images/og-image.png" />
    <meta property="og:locale" content="sv_SE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://changebrief.io/images/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <slot />
  </body>
</html>
